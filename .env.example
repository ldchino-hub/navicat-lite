# Copia a .env y ajusta antes de: docker compose up -d
NAVICAT_LITE_PORT=8789

# Generar: openssl rand -hex 32
META_ENC_KEY=

# Generar: openssl rand -hex 16
JWT_SECRET=

ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=

# true en primer arranque; false después de crear admin
SEED_ADMIN=true

# Opcional: bridge MySQL remoto (dejar vacío si no aplica)
MYSQL_BRIDGE_URL=
MYSQL_BRIDGE_KEY=
MYSQL_BRIDGE_HOSTS=
