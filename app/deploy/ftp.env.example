# Copy to deploy/ftp.env and fill in (deploy/ftp.env is gitignored).
#
#   cp deploy/ftp.env.example deploy/ftp.env

FTP_HOST=ldjr.me
FTP_USER=db@ldjr.me
FTP_PASS=your-ftp-password

# Public URL used for post-deploy checks
DEPLOY_URL=https://db.ldjr.me

# Upload config/config.php on full deploy (default: skip — keeps server secrets safe)
# DEPLOY_UPLOAD_CONFIG=1

# Upload public/check.php diagnostic (default: skip on production)
# DEPLOY_UPLOAD_CHECK=1

# Remove stale hashed JS/CSS on FTP after frontend deploy (default: 1)
# DEPLOY_PRUNE_ASSETS=1
